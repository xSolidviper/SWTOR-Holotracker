<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <AssemblyName>SWTOR Holotracker Setup</AssemblyName>
    <RootNamespace>SwtorHolotrackerInstaller</RootNamespace>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>..\data\images\Icon-removebg-preview.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\artifacts\installer-gui\payload\app.zip" LogicalName="app.zip" />
  </ItemGroup>

</Project>
